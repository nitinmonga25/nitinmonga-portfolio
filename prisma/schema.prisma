generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  description String   @db.Text
  longDesc    String?  @db.LongText
  category    String
  thumbnail   String
  images      String?  @db.Text
  liveUrl     String?
  featured    Boolean  @default(false)
  order       Int      @default(0)
  tags        String?  @db.Text
  techStack   String?  @db.Text
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("projects")
}

model BlogPost {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  excerpt     String    @db.Text
  content     String    @db.LongText
  category    String
  thumbnail   String?
  tags        String?   @db.Text
  published   Boolean   @default(false)
  publishedAt DateTime?
  seoTitle    String?
  seoDesc     String?   @db.Text
  readTime    Int       @default(5)
  views       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("blog_posts")
}

model Service {
  id           Int      @id @default(autoincrement())
  title        String
  description  String   @db.Text
  icon         String
  startingPrice String?
  deliverables String?  @db.Text
  order        Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("services")
}

model Skill {
  id         Int      @id @default(autoincrement())
  name       String
  percentage Int
  category   SkillCategory
  icon       String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("skills")
}

enum SkillCategory {
  DESIGN
  DEV
  THREE_D
  SEO
}

model Product {
  id           Int      @id @default(autoincrement())
  name         String
  url          String
  screenshot   String?
  monthlyUsers Int      @default(0)
  techStack    String?  @db.Text
  role         String?
  description  String?  @db.Text
  order        Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("products")
}

model SiteSetting {
  id        Int          @id @default(autoincrement())
  key       String       @unique
  value     String       @db.Text
  type      SettingType  @default(TEXT)
  updatedAt DateTime     @updatedAt

  @@map("site_settings")
}

enum SettingType {
  TEXT
  JSON
  BOOLEAN
  NUMBER
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  service   String?
  message   String   @db.Text
  budget    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model TimelineMilestone {
  id          Int      @id @default(autoincrement())
  year        String
  title       String
  description String   @db.Text
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("timeline_milestones")
}

model UIAnalysis {
  id                 String   @id @default(cuid())
  uuid               String   @unique @default(uuid())
  imageUrl           String
  mode               String
  totalScore         Int
  colorScore         Int
  spacingScore       Int
  alignmentScore     Int
  consistencyScore   Int
  radiusScore        Int
  hierarchyScore     Int
  typographyScore    Int
  colorFeedback      String   @db.Text
  spacingFeedback    String   @db.Text
  alignFeedback      String   @db.Text
  consistFeedback    String   @db.Text
  radiusFeedback     String   @db.Text
  hierarchyFeedback  String   @db.Text
  typographyFeedback String   @db.Text
  improvements       String   @db.Text
  palette            String   @db.Text
  createdAt          DateTime @default(now())
  ipHash             String

  @@map("ui_analyses")
}
